# ─────────────────────────────────────────────────────────────
# ResuMatch — environment variables
# Copy this file to `.env.local` (gitignored) and fill in real values.
# In Vercel, add each of these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API
# URL + anon key are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC.
# Used by the resume-parse route to read the private storage bucket.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Groq (AI parsing) ─────────────────────────────────────────
# https://console.groq.com/keys  (free developer tier)
GROQ_API_KEY=gsk_your_groq_api_key
# Optional override; defaults to openai/gpt-oss-20b in code.
GROQ_MODEL=openai/gpt-oss-20b

# ── App ───────────────────────────────────────────────────────
# Public base URL of the deployed app (used for OAuth redirect).
# Local dev: http://localhost:3000   |   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────
# You do NOT set the Google client ID/secret here. They are configured
# inside Supabase: Authentication → Providers → Google.
# In Google Cloud Console add this Authorized redirect URI:
#   https://YOUR-PROJECT-ref.supabase.co/auth/v1/callback
